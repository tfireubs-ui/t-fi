{
  "name": "agent-news",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "wrangler": "set -a && . ./.env && set +a && npx wrangler",
    "dev": "npm run wrangler -- dev",
    "deploy": "npm run wrangler -- deploy",
    "deploy:dry-run": "npm run wrangler -- deploy --dry-run",
    "dev:staging": "npm run wrangler -- dev --env staging",
    "deploy:dry-run:staging": "npm run wrangler -- deploy --dry-run --env staging",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "cf-typegen": "npm run wrangler -- types",
    "migrate": "set -a && . ./.env && set +a && npx tsx scripts/migrate-kv-to-do.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@cloudflare/vitest-pool-workers": "^0.13.0",
    "@cloudflare/workers-types": "^4.20241205.0",
    "@types/node": "^25.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.0.0"
  },
  "dependencies": {
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@noble/secp256k1": "^2.1.0",
    "@scure/base": "^2.0.0",
    "@scure/btc-signer": "^2.0.1",
    "hono": "^4.6.0"
  }
}
